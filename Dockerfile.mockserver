# Build stage
FROM golang:1.22-alpine AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY cmd/mockserver/ ./cmd/mockserver/

RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /mockserver ./cmd/mockserver

# Runtime stage — minimal image, no shell needed
FROM alpine:3.21

RUN apk add --no-cache wget

COPY --from=builder /mockserver /mockserver

EXPOSE 9000

ENTRYPOINT ["/mockserver"]
