# Copy to .env and fill values.
#
# Target gateway URLs (without trailing slash)
FERROGATEWAY_URL=http://localhost:8080
LITELLM_URL=http://localhost:4000
PORTKEY_URL=http://localhost:8787
KONG_URL=http://localhost:8000

# API keys/tokens used by each gateway route (if required)
FERROGATEWAY_API_KEY=
LITELLM_API_KEY=
PORTKEY_API_KEY=
KONG_API_KEY=

# Upstream model name that all gateways map to
MODEL=gpt-4o-mini

# Set to http://localhost:9000 to route all gateways through the local mock
# server (scripts/mock_server.py) for isolated overhead measurement.
MOCK_SERVER_URL=
