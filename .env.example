# Copy to .env and adjust values as needed.
#
# Gateway URLs — each gateway runs as a native process on localhost.
FERROGATEWAY_URL=http://localhost:8080
LITELLM_URL=http://localhost:4000
KONG_URL=http://localhost:8000
BIFROST_URL=http://localhost:8081
PORTKEY_URL=http://localhost:8787

# API keys/tokens (leave empty or set to mock-key for mock-server mode)
FERROGATEWAY_API_KEY=mock-key
LITELLM_API_KEY=mock-key
KONG_API_KEY=
BIFROST_API_KEY=mock-key
PORTKEY_API_KEY=mock-key

# Upstream model name forwarded in request bodies
MODEL=gpt-4o
# Bifrost v1.0.0 requires provider/model format
BIFROST_MODEL=openai/gpt-4o

# Mock server URL (used by Portkey custom-host header)
MOCK_SERVER_URL=http://localhost:9000
PORTKEY_UPSTREAM_URL=http://localhost:9000/v1
