# Copy to .env and fill values.
#
# Target gateway URLs (without trailing slash).
# These match the port-forwarded addresses from docker-compose.yml.
FERROGATEWAY_URL=http://localhost:8080
LITELLM_URL=http://localhost:4000
PORTKEY_URL=http://localhost:8787
KONG_URL=http://localhost:8000
BIFROST_URL=http://localhost:9100

# API keys/tokens used by each gateway (leave empty for mock-server mode)
FERROGATEWAY_API_KEY=
LITELLM_API_KEY=
PORTKEY_API_KEY=mock-key
KONG_API_KEY=
BIFROST_API_KEY=

# Upstream model name forwarded in request bodies
MODEL=gpt-4o-mini

# Portkey: upstream base URL sent via x-portkey-custom-host header.
# In isolated Docker mode this must be the Docker-internal mock hostname.
# Set to empty string to skip the override and route to real OpenAI.
PORTKEY_UPSTREAM_URL=http://mock-server:9000

# Set to http://localhost:9000 when running the mock server manually
# (outside Docker) for local testing without docker-compose.
MOCK_SERVER_URL=http://localhost:9000
