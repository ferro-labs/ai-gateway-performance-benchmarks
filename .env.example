# Copy to .env and adjust values as needed.
#
# ─── Gateway URLs ────────────────────────────────────────────────
# Each gateway runs as a native process on localhost.
FERROGATEWAY_URL=http://localhost:8080       # Ferro Labs AI Gateway (port 8080)
LITELLM_URL=http://localhost:4000            # LiteLLM Proxy (port 4000)
KONG_URL=http://localhost:8000               # Kong OSS proxy (port 8000)
BIFROST_URL=http://localhost:8081            # Bifrost (port 8081)
PORTKEY_URL=http://localhost:8787            # Portkey self-hosted (port 8787)

# ─── API Keys / Tokens ──────────────────────────────────────────
# Set to "mock-key" for mock-server mode. Real keys for live upstream tests.
FERROGATEWAY_API_KEY=mock-key
LITELLM_API_KEY=mock-key                     # Must match master_key in litellm config
KONG_API_KEY=                                # Kong OSS does not require an API key
BIFROST_API_KEY=mock-key
PORTKEY_API_KEY=mock-key

# ─── Model Names ─────────────────────────────────────────────────
# Upstream model name forwarded in request bodies
MODEL=gpt-4o
# Bifrost v1.0.0 requires provider/model format
BIFROST_MODEL=openai/gpt-4o

# ─── Mock Server / Upstream ──────────────────────────────────────
# Mock server URL (used by Portkey custom-host header)
MOCK_SERVER_URL=http://localhost:9000
# Portkey requires /v1 suffix for OpenAI-compatible routing
PORTKEY_UPSTREAM_URL=http://localhost:9000/v1

# Portkey Self-Hosted Gateway — Benchmark Config
# Version: latest (portkeyai/gateway Docker image)
# Hardware: GCP n2-standard-8 (8 vCPU, 32GB RAM), Debian 12
# Started by: Docker --network host (see start_portkey())
# Tuning: default configuration, no custom tuning applied
# Upstream: http://localhost:9000/v1 (60ms mock server)
# Note: Requires x-portkey-custom-host header for routing
# Note: Native Node.js had concurrency issues — Docker required
